# Copy to .env.local for local overrides (never commit secrets).
# Vite only exposes variables prefixed with VITE_ to the browser.

# --- Product (optional; app uses sensible samples if unset) ---
# VITE_CONTACT_EMAIL=you@yourdomain.com
# VITE_LEGAL_ENTITY=Your Company or Name LLC
# VITE_PUBLIC_SITE_URL=https://yourdomain.com

# CultureWorks calendar API (default is Richmond CultureWorks)
# VITE_CULTUREWORKS_EVENTS_URL=https://calendar.richmondcultureworks.org/api/2/events

# When a listing has no image, cards use this URL
# VITE_DEFAULT_EVENT_IMAGE_URL=https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=800&q=80

# Display / “tonight” logic (IANA timezone)
# VITE_EVENT_TIMEZONE=America/New_York

# --- Eventbrite (optional) ---
# Private token from https://www.eventbrite.com/platform/api — NOT prefixed with VITE_ (server/dev proxy only).
# In dev, Vite proxies /eventbrite-api → Eventbrite v3 with this header.
# EVENTBRITE_PRIVATE_TOKEN=

# Production: browser cannot call Eventbrite directly (CORS). Point this at your own HTTPS proxy
# that forwards to https://www.eventbriteapi.com/v3 with the token server-side.
# VITE_EVENTBRITE_PROXY=https://your-worker.example.com/eventbrite

# Optional (unused by default)
# VITE_EVENTBRITE_ORG_IDS=123,456
# VITE_RSS_FEED_URLS=https://example.org/feed.xml
# VITE_API_PROXY_BASE=/api
