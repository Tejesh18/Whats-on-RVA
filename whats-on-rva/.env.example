# Copy to .env.local for local overrides (never commit secrets).
# Vite only exposes variables prefixed with VITE_ to the browser.

# CultureWorks Localist — default matches production Richmond calendar
# VITE_CULTUREWORKS_EVENTS_URL=https://calendar.richmondcultureworks.org/api/2/events

# When a listing has no image, cards use this URL
# VITE_DEFAULT_EVENT_IMAGE_URL=https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=800&q=80

# Display / “tonight” logic (IANA timezone)
# VITE_EVENT_TIMEZONE=America/New_York

# --- Future integration (not wired in MVP UI yet) ---
# VITE_EVENTBRITE_ORG_IDS=123,456
# VITE_RSS_FEED_URLS=https://example.org/feed.xml
# VITE_API_PROXY_BASE=/api
